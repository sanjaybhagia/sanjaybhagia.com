---
import fs from 'node:fs';
import { imageSize } from 'image-size';
import Base from '../../layouts/Base.astro';

const shot = {
  src: '/images/projects/calendar-app.webp',
  alt: 'Calendar on Your Wall — a full 2026 annual calendar ready to personalize and print',
  ...imageSize(fs.readFileSync('./public/images/projects/calendar-app.webp')),
};
---
<Base
  title="Calendar on Your Wall"
  description="Personalize, print & plan — a yearly wall calendar with your events and public holidays, synced from Google Calendar."
>
  <p class="eyebrow">Web App</p>
  <h1>Calendar on Your Wall</h1>
  <p class="lede">
    Personalize, print &amp; plan — a yearly wall calendar with your events and
    public holidays on it.
  </p>

  <div class="cta-row">
    <a class="btn" href="https://calendaronyourwall.com">Open the app</a>
  </div>

  <section aria-labelledby="cal-shot">
    <p class="eyebrow" id="cal-shot">A look</p>
    <p class="shot-wide">
      <img src={shot.src} alt={shot.alt} width={shot.width} height={shot.height} loading="lazy" decoding="async" />
    </p>
  </section>

  <section aria-labelledby="cal-features">
    <p class="eyebrow" id="cal-features">Features</p>
    <div class="prose">
      <ul>
        <li>Public holidays for your country and state, added automatically</li>
        <li>Google Calendar sync — your own events flow onto the wall calendar</li>
        <li>Custom colours and date ranges</li>
        <li>Download as a print-ready PDF, or order a printed calendar</li>
        <li>Works with secondary calendars you own; events can also stay local</li>
      </ul>
    </div>
  </section>

  <section aria-labelledby="cal-how">
    <p class="eyebrow" id="cal-how">How it works</p>
    <div class="prose">
      <ol>
        <li>Pick your country and state to load public holidays</li>
        <li>Connect Google Calendar if you want your events synced</li>
        <li>Customise colours and the date range</li>
        <li>Download the PDF and print it — or buy a printed copy</li>
      </ol>
      <p>Free to use; printed calendars available to order.</p>
    </div>
  </section>

  <p class="more-link"><a class="quiet" href="/projects/">← All projects</a></p>
</Base>
