---
import Base from '../../layouts/Base.astro';
---
<Base
  title="ParkingQuest"
  description="Know before you go — live Park&Ride occupancy for 30+ Sydney car parks, right on your iPhone Lock Screen."
>
  <p class="eyebrow">iOS App</p>
  <h1>ParkingQuest</h1>
  <p class="lede">
    Know before you go — live Park&amp;Ride occupancy for Sydney commuters,
    right on your iPhone Lock Screen.
  </p>

  <div class="cta-row">
    <a class="btn" href="https://apps.apple.com/au/app/parkingquest/id6783192586">Download on the App Store</a>
    <a class="btn secondary" href="https://parkingquest.app">parkingquest.app</a>
  </div>

  <section aria-labelledby="pq-features">
    <p class="eyebrow" id="pq-features">Features</p>
    <div class="prose">
      <ul>
        <li>Real-time space counts on your Lock Screen — no need to open an app</li>
        <li>Colour-coded availability, from green to red as car parks fill</li>
        <li>Fill alerts when your car park is about to reach capacity</li>
        <li>One-tap directions via Apple Maps or Google Maps</li>
        <li>Customisable commute schedule with live updates when you need them</li>
        <li>No account, no subscription, no ads, no tracking</li>
        <li>Powered by official Transport for NSW Open Data</li>
      </ul>
    </div>
  </section>

  <section aria-labelledby="pq-coverage">
    <p class="eyebrow" id="pq-coverage">Coverage</p>
    <div class="prose">
      <p>
        30+ Park&amp;Ride car parks across Sydney Metro (Tallawong to Hills
        Showground), the Northern Beaches B-Line (Brookvale to Manly Vale), and
        Sydney Trains &amp; Intercity lines from Emu Plains to Kiama — with new
        locations added automatically as Transport for NSW opens them.
      </p>
      <p>Free. Requires iOS 16.2 or later.</p>
    </div>
  </section>
</Base>
