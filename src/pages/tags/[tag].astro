---
import Base from '../../layouts/Base.astro';
import PostList from '../../components/PostList.astro';
import { collectTags } from '../../lib/tags';
import { getPublishedPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return [...collectTags(posts).entries()].map(([slug, { name, posts }]) => ({
    params: { tag: slug },
    props: {
      name,
      posts: posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { name, posts } = Astro.props;
---
<Base title={`Tagged “${name}”`} description={`Posts tagged ${name}.`}>
  <p class="eyebrow">Topic</p>
  <h1>{name}</h1>
  <PostList posts={posts} />
  <p class="more-link"><a class="quiet" href="/tags/">All tags →</a></p>
</Base>
