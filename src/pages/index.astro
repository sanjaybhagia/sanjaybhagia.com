---
import Base from '../layouts/Base.astro';
import PostList from '../components/PostList.astro';
import { getPublishedPosts } from '../lib/posts';

const recent = (await getPublishedPosts()).slice(0, 4);

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sanjay Bhagia',
  url: 'https://sanjaybhagia.com',
  jobTitle: 'Cloud Solutions Architect & Developer',
  worksFor: { '@type': 'Organization', name: 'Inauro' },
  sameAs: [
    'https://github.com/sanjaybhagia',
    'https://www.linkedin.com/in/sanjaybhagia/',
    'https://twitter.com/bhagiasanjay',
  ],
};
---
<Base>
  <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
  <h1>G'day, I'm Sanjay.</h1>
  <p class="lede">
    I design cloud systems for a living and build apps for the joy of it —
    <a class="quiet" href="/apps/parkingquest/">ParkingQuest</a> for Sydney commuters,
    <a class="quiet" href="/apps/calendar-on-your-wall/">wall calendars</a> you can
    actually print. This site is where I think out loud, and has been since 2012.
  </p>

  <section aria-labelledby="apps-h">
    <p class="eyebrow" id="apps-h">Apps &amp; projects</p>
    <div class="cards">
      <div class="card">
        <span class="kind">iOS App</span>
        <h3><a href="/apps/parkingquest/">ParkingQuest</a></h3>
        <p>Know before you go — live Park&amp;Ride occupancy for 30+ Sydney car parks, right on your iPhone Lock Screen.</p>
      </div>
      <div class="card">
        <span class="kind">Web App</span>
        <h3><a href="/apps/calendar-on-your-wall/">Calendar on Your Wall</a></h3>
        <p>Personalize, print &amp; plan — printable calendars with your events and holidays, synced from Google Calendar.</p>
      </div>
      <div class="card">
        <span class="kind">Course</span>
        <h3><a href="https://www.educative.io/courses/cloud-computing-fundamentals">Cloud Computing Fundamentals</a></h3>
        <p>My interactive course on Educative — the what, why and how of cloud computing.</p>
      </div>
    </div>
    <p class="more-link"><a class="quiet" href="/apps/">All apps →</a></p>
  </section>

  <section aria-labelledby="recent-h">
    <p class="eyebrow" id="recent-h">Recent writing</p>
    <PostList posts={recent} />
    <p class="more-link"><a class="quiet" href="/blog/">All posts →</a></p>
  </section>
</Base>
