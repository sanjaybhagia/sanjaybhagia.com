---
import '../styles/global.css';
import Subscribe from '../components/Subscribe.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const siteTitle = "Sanjay Bhagia";
const {
  title,
  description = "The personal blog of Sanjay Bhagia — .NET, Azure, CI/CD and technology in general.",
  image,
} = Astro.props;

const pageTitle = title ? `${title} · ${siteTitle}` : `${siteTitle} — Building things, writing them down`;
const path = Astro.url.pathname;
const current = (prefix: string) =>
  (prefix === '/' ? path === '/' : path.startsWith(prefix)) ? 'page' : undefined;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(path, Astro.site)} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title ?? siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(path, Astro.site)} />
    <meta property="og:type" content={path.startsWith('/blog/') ? 'article' : 'website'} />
    {image && <meta property="og:image" content={new URL(image, Astro.site)} />}
  </head>
  <body>
    <div class="shell">
      <header class="site">
        <a class="wordmark" href="/">Sanjay Bhagia</a>
        <nav class="main" aria-label="Site">
          <a href="/" aria-current={current('/')}>Home</a>
          <a href="/blog" aria-current={current('/blog')}>Blog</a>
          <a href="/tags" aria-current={current('/tags')}>Tags</a>
          <a href="/tools" aria-current={current('/tools')}>Tools</a>
          <a href="/about" aria-current={current('/about')}>About</a>
        </nav>
      </header>
      <main>
        <slot />
        <Subscribe />
      </main>
      <footer class="site">
        <span>© Sanjay Bhagia · <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a></span>
        <span class="links">
          <a href="/rss.xml">RSS</a>
          <a href="https://github.com/sanjaybhagia">GitHub</a>
          <a href="https://www.linkedin.com/in/sanjaybhagia/">LinkedIn</a>
          <a href="https://twitter.com/bhagiasanjay">X</a>
        </span>
      </footer>
    </div>
  </body>
</html>
