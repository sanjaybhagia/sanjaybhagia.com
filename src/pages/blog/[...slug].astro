---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Comments from '../../components/Comments.astro';
import PostList from '../../components/PostList.astro';
import Toc from '../../components/Toc.astro';
import { tagSlug } from '../../lib/tags';
import { getPublishedPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post, i) => {
    const related = posts
      .filter((p) => p.id !== post.id)
      .map((p) => ({
        p,
        score: p.data.tags.filter((t) => post.data.tags.includes(t)).length,
      }))
      .filter((x) => x.score > 0)
      .sort((a, b) => b.score - a.score || b.p.data.date.valueOf() - a.p.data.date.valueOf())
      .slice(0, 3)
      .map((x) => x.p);
    return {
      params: { slug: post.id },
      props: { post, newer: posts[i - 1] ?? null, older: posts[i + 1] ?? null, related },
    };
  });
}

const { post, newer, older, related } = Astro.props;
const { Content, headings } = await render(post);

const hasToc = headings.filter((h) => h.depth >= 1 && h.depth <= 3).length > 2;

let heroDims: { width?: number; height?: number } = {};
if (post.data.image?.startsWith('/images/')) {
  const fs = await import('node:fs');
  const { imageSize } = await import('image-size');
  try {
    heroDims = imageSize(fs.readFileSync(`./public${post.data.image}`));
  } catch {
    // unknown dimensions: render unsized
  }
}

const words = post.body ? post.body.split(/\s+/).length : 0;
const minutes = Math.max(1, Math.round(words / 200));
const dateLabel = post.data.date.toLocaleDateString('en-AU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});

const postLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString().slice(0, 10),
  url: `https://sanjaybhagia.com/blog/${post.id}/`,
  image: new URL(post.data.image ?? `/og/${post.id}.png`, 'https://sanjaybhagia.com').href,
  author: {
    '@type': 'Person',
    name: 'Sanjay Bhagia',
    url: 'https://sanjaybhagia.com/about',
  },
};
---
<Base
  title={post.data.title}
  description={post.data.description}
  image={post.data.image ?? `/og/${post.id}.png`}
>
  <script type="application/ld+json" set:html={JSON.stringify(postLd)} />
  <article class:list={['post', { 'has-toc': hasToc }]} data-pagefind-body>
    <div class="post-body">
    <p class="meta">
      <time datetime={post.data.date.toISOString()}>{dateLabel}</time> · {minutes} min read
    </p>
    <h1>{post.data.title}</h1>
    {post.data.tags.length > 0 && (
      <ul class="tags">
        {post.data.tags.map((tag) => (
          <li><a href={`/tags/${tagSlug(tag)}/`}>{tag}</a></li>
        ))}
      </ul>
    )}
    {post.data.image && (
      <img
        class="post-hero"
        src={post.data.image}
        alt=""
        width={heroDims.width}
        height={heroDims.height}
        fetchpriority="high"
      />
    )}
    <Toc headings={headings} class="toc-inline" />
    <div class="prose">
      <Content />
    </div>
    <nav class="prevnext" aria-label="Adjacent posts">
      {older ? <a class="quiet" href={`/blog/${older.id}/`}>← {older.data.title}</a> : <span></span>}
      {newer ? <a class="quiet" href={`/blog/${newer.id}/`}>{newer.data.title} →</a> : <span></span>}
    </nav>
    {related.length > 0 && (
      <section aria-labelledby="readnext-h" data-pagefind-ignore>
        <p class="eyebrow" id="readnext-h">Read next</p>
        <PostList posts={related} />
      </section>
    )}
    <Comments />
    </div>
    {hasToc && (
      <aside class="post-aside">
        <Toc headings={headings} />
      </aside>
    )}
  </article>
</Base>
