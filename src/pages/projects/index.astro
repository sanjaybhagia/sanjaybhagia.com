---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Apps & projects"
  description="Things I've shipped — ParkingQuest, Calendar on Your Wall, and my Cloud Computing Fundamentals course."
>
  <p class="eyebrow">Making</p>
  <h1>Apps &amp; projects</h1>
  <p class="lede">Things I've shipped and maintain — built for problems I actually have.</p>

  <section aria-label="All projects and projects">
    <div class="cards">
      <div class="card">
        <div class="card-top">
          <span class="kind">iOS App</span>
          <img class="card-icon" src="/images/projects/parkingquest-icon.png" alt="" width="44" height="44" loading="lazy" />
        </div>
        <h3><a href="/projects/parkingquest/">ParkingQuest</a></h3>
        <p>
          Know before you go — live Park&amp;Ride occupancy for 30+ Sydney car
          parks, right on your iPhone Lock Screen. Free, no ads, no tracking.
        </p>
        <p class="card-links">
          <a class="quiet" href="/projects/parkingquest/">Details →</a>
          <a class="quiet" href="https://apps.apple.com/au/app/parkingquest/id6783192586">App Store</a>
        </p>
      </div>
      <div class="card">
        <div class="card-top">
          <span class="kind">Web App</span>
          <img class="card-icon" src="/images/projects/calendar-icon.png" alt="" width="44" height="44" loading="lazy" />
        </div>
        <h3><a href="/projects/calendar-on-your-wall/">Calendar on Your Wall</a></h3>
        <p>
          Personalize, print &amp; plan — printable yearly calendars with your
          events and public holidays, synced from Google Calendar.
        </p>
        <p class="card-links">
          <a class="quiet" href="/projects/calendar-on-your-wall/">Details →</a>
          <a class="quiet" href="https://calendaronyourwall.com">Open the app</a>
        </p>
      </div>
      <div class="card">
        <div class="card-top">
          <span class="kind">Course</span>
          <img class="card-icon" src="/images/projects/course-icon.png" alt="" width="44" height="44" loading="lazy" />
        </div>
        <h3><a href="https://www.educative.io/courses/cloud-computing-fundamentals">Cloud Computing Fundamentals</a></h3>
        <p>
          My interactive course on Educative — the what, why and how of cloud
          computing, hands-on in the browser.
        </p>
        <p class="card-links">
          <a class="quiet" href="https://www.educative.io/courses/cloud-computing-fundamentals">On Educative</a>
        </p>
      </div>
    </div>
  </section>
</Base>
