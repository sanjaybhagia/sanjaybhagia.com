---
// giscus (comments via GitHub Discussions) — https://giscus.app
// To enable: turn on Discussions for the repo, install the giscus app,
// then fill in the two IDs from giscus.app below.
const GISCUS_REPO = ''; // e.g. 'sanjaybhagia/sanjaybhagia.github.io'
const GISCUS_REPO_ID = '';
const GISCUS_CATEGORY_ID = '';
---
{GISCUS_REPO && (
  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo={GISCUS_REPO}
    data-repo-id={GISCUS_REPO_ID}
    data-mapping="pathname"
    data-category-id={GISCUS_CATEGORY_ID}
    data-reactions-enabled="1"
    data-input-position="bottom"
    data-theme="preferred_color_scheme"
    data-lang="en"
    crossorigin="anonymous"
    async
  ></script>
)}
