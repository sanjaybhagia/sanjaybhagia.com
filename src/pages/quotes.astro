---
// Data-driven from src/data/quotes.json. Deliberately NOT linked in the nav
// until real quotes replace the sample entries.
import Base from '../layouts/Base.astro';
import quotes from '../data/quotes.json';
---
<Base title="Quotes" description="Passages worth keeping, captured from the books I read.">
  <p class="eyebrow">Commonplace book</p>
  <h1>Quotes</h1>
  <p class="lede">Passages worth keeping, captured from the books I read.</p>

  <section>
    {quotes.map((q) => (
      <blockquote class="quote">
        <p>“{q.text}”</p>
        <footer>{q.author}{q.source ? ` — ${q.source}` : ''}</footer>
      </blockquote>
    ))}
  </section>
</Base>
