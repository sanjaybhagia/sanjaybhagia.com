---
// Data-driven from src/data/reading.json.
import Base from '../layouts/Base.astro';
import reading from '../data/reading.json';
---
<Base title="Reading" description="What I'm reading now and what I've finished.">
  <p class="eyebrow">Bookshelf</p>
  <h1>Reading</h1>

  <section aria-labelledby="reading-now">
    <p class="eyebrow" id="reading-now">Currently reading</p>
    <ul class="post-list">
      {reading.current.map((b) => (
        <li><span>{b.title} — {b.author}</span></li>
      ))}
    </ul>
  </section>

  <section aria-labelledby="reading-done">
    <p class="eyebrow" id="reading-done">Finished</p>
    <ul class="post-list">
      {reading.finished.map((b) => (
        <li>
          <time>{b.year ?? ''}</time>
          <span>{b.title} — {b.author}</span>
        </li>
      ))}
    </ul>
  </section>
</Base>
